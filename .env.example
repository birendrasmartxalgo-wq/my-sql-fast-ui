# MySQL connection for the built-in local server (connection id 0)
MYSQL_HOST=127.0.0.1        # use 127.0.0.1, not "localhost"
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_MAINT_DB=mysql

# Web UI
ADMIN_PASSWORD=change-me     # gates the UI and every saved server
PORT=4602

# Optional — enables natural-language SQL + fix-my-query (key stays server-side)
# ANTHROPIC_API_KEY=sk-ant-...
# AI_MODEL=claude-opus-4-8
