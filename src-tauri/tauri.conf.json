{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mysql-fast-ui",
  "version": "2.0.0",
  "identifier": "com.smartxalgo.mysqlfastui",
  "build": {
    "frontendDist": "./placeholder"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/mysql-fast-server"],
    "resources": {
      "../public": "public",
      "../tools/mysql": "tools/mysql"
    }
  }
}
