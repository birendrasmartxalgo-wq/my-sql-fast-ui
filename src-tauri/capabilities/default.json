{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Allow the app to spawn the bundled Bun server sidecar.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [{ "name": "binaries/mysql-fast-server", "sidecar": true }]
    }
  ]
}
